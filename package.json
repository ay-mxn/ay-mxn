{
  "name": "ay-readme",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "scripts": {
    "stats": "if [ -f .env ]; then bunx tsm --env-file .env scripts/stats.ts; else bunx tsm scripts/stats.ts; fi",
    "build": "bunx tsm scripts/build.ts",
    "go": "bun run stats && bun run build",
    "format": "prettier --write ./{src,scripts}/*"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prettier": "^3.3.2",
    "tsm": "^2.3.0",
    "typescript": "^5.5.3"
  }
}
